{
  "name": "sysflow-client",
  "version": "0.1.0",
  "description": "Sysflow CLI - AI coding agent with local tool execution",
  "type": "module",
  "bin": {
    "sys": "./bin/sys.js"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "link": "npm link"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "ora": "^9.3.0",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  }
}
